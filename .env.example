# Show/hide floating debug button in editor (dev mode only)
# Set to 'false' to hide debug panel button during development
VITE_SHOW_DEBUG_PANEL=true
# Evolink.ai API key for AI video/image generation (Seedance 2.0 + Nanobanana 2)
# Get your key at https://evolink.ai/dashboard/keys
# VITE_EVOLINK_API_KEY=
