const form = new FormData();
form.append('prompt', '<string>');
form.append('image', '<string>');
form.append('model_id', '');
form.append('safety_check', 'true');
form.append('seed', '123');
form.append('num_inference_steps', '75');

const options = {method: 'POST', headers: {Authorization: 'Bearer <token>'}};

options.body = form;

fetch('https://livepeer.studio/api/beta/generate/upscale', options)
  .then(res => res.json())
  .then(res => console.log(res))
  .catch(err => console.error(err));

