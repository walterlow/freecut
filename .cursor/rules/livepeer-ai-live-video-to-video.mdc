  method: 'POST',
  headers: {Authorization: 'Bearer <token>', 'Content-Type': 'application/json'},
  body: JSON.stringify({
    subscribe_url: '<string>',
    publish_url: '<string>',
    control_url: '',
    events_url: '',
    model_id: '',
    params: {}
  })
};

fetch('https://livepeer.studio/api/beta/generate/live-video-to-video', options)
