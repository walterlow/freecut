{
  "name": "@freecut/core",
  "version": "0.0.1",
  "description": "Shared FreeCut domain planning helpers for projects, workspaces, render ranges, and media readiness.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./range": {
      "types": "./dist/range.d.ts",
      "default": "./dist/range.js"
    },
    "./project": {
      "types": "./dist/project.d.ts",
      "default": "./dist/project.js"
    },
    "./snapshot": {
      "types": "./dist/snapshot.d.ts",
      "default": "./dist/snapshot.js"
    },
    "./validation": {
      "types": "./dist/validation.d.ts",
      "default": "./dist/validation.js"
    },
    "./media-plan": {
      "types": "./dist/media-plan.d.ts",
      "default": "./dist/media-plan.js"
    },
    "./render-plan": {
      "types": "./dist/render-plan.d.ts",
      "default": "./dist/render-plan.js"
    },
    "./workspace": {
      "types": "./dist/workspace.d.ts",
      "default": "./dist/workspace.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "prepare": "npm run build",
    "test": "npm run build && vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "~5.9.3",
    "vitest": "^4.0.17"
  },
  "license": "MIT"
}
