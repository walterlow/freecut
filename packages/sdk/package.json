{
  "name": "@freecut/sdk",
  "version": "0.0.1",
  "description": "Programmatic authoring of FreeCut projects. Pure-data TypeScript SDK for building .fcproject snapshots that the FreeCut editor can open.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "prepare": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "freecut",
    "video",
    "editor",
    "sdk"
  ],
  "license": "MIT",
  "dependencies": {
    "@freecut/core": "0.0.1"
  },
  "devDependencies": {
    "typescript": "~5.9.3",
    "vitest": "^4.0.17"
  }
}
